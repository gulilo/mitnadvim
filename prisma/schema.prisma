generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model account {
  id                                                            String                 @id(map: "user_pkey") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  display_name                                                  String                 @db.VarChar(255)
  email                                                         String                 @unique(map: "user_email_key") @db.VarChar(255)
  created_at                                                    DateTime               @default(now()) @db.Timestamptz(6)
  updated_at                                                    DateTime?              @db.Timestamptz(6)
  created_by                                                    String                 @db.Uuid
  updated_by                                                    String?                @db.Uuid
  password_hash                                                 String?
  phone                                                         String?                @db.VarChar(50)
  account_tag_account_tag_account_idToaccount                   account_tag[]          @relation("account_tag_account_idToaccount")
  account_tag_account_tag_created_byToaccount                   account_tag[]          @relation("account_tag_created_byToaccount")
  account_tag_account_tag_updated_byToaccount                   account_tag[]          @relation("account_tag_updated_byToaccount")
  ambulance_ambulance_created_byToaccount                       ambulance[]            @relation("ambulance_created_byToaccount")
  ambulance_ambulance_updated_byToaccount                       ambulance[]            @relation("ambulance_updated_byToaccount")
  area_area_created_byToaccount                                 area[]                 @relation("area_created_byToaccount")
  area_area_updated_byToaccount                                 area[]                 @relation("area_updated_byToaccount")
  emergency_contacts_emergency_contacts_created_byToaccount     emergency_contacts[]   @relation("emergency_contacts_created_byToaccount")
  emergency_contacts_emergency_contacts_updated_byToaccount     emergency_contacts[]   @relation("emergency_contacts_updated_byToaccount")
  launch_point_launch_point_created_byToaccount                 launch_point[]         @relation("launch_point_created_byToaccount")
  launch_point_launch_point_updated_byToaccount                 launch_point[]         @relation("launch_point_updated_byToaccount")
  notification_notification_created_byToaccount                 notification[]         @relation("notification_created_byToaccount")
  notification_notification_updated_byToaccount                 notification[]         @relation("notification_updated_byToaccount")
  notification_notification_user_idToaccount                    notification[]         @relation("notification_user_idToaccount")
  password_reset_token_password_reset_token_account_idToaccount password_reset_token[] @relation("password_reset_token_account_idToaccount")
  password_reset_token_password_reset_token_created_byToaccount password_reset_token[] @relation("password_reset_token_created_byToaccount")
  password_reset_token_password_reset_token_updated_byToaccount password_reset_token[] @relation("password_reset_token_updated_byToaccount")
  permanent_shift_permanent_shift_created_byToaccount           permanent_shift[]      @relation("permanent_shift_created_byToaccount")
  permanent_shift_permanent_shift_updated_byToaccount           permanent_shift[]      @relation("permanent_shift_updated_byToaccount")
  permissions_permissions_created_byToaccount                   permissions[]          @relation("permissions_created_byToaccount")
  permissions_permissions_updated_byToaccount                   permissions[]          @relation("permissions_updated_byToaccount")
  shift_shift_created_byToaccount                               shift[]                @relation("shift_created_byToaccount")
  shift_shift_driver_idToaccount                                shift[]                @relation("shift_driver_idToaccount")
  shift_shift_updated_byToaccount                               shift[]                @relation("shift_updated_byToaccount")
  shift_slot_shift_slot_created_byToaccount                     shift_slot[]           @relation("shift_slot_created_byToaccount")
  shift_slot_shift_slot_updated_byToaccount                     shift_slot[]           @relation("shift_slot_updated_byToaccount")
  shift_slot_shift_slot_user_idToaccount                        shift_slot[]           @relation("shift_slot_user_idToaccount")
  tag_tag_created_byToaccount                                   tag[]                  @relation("tag_created_byToaccount")
  tag_tag_updated_byToaccount                                   tag[]                  @relation("tag_updated_byToaccount")
  tag_permission_tag_permission_created_byToaccount             tag_permission[]       @relation("tag_permission_created_byToaccount")
  tag_permission_tag_permission_updated_byToaccount             tag_permission[]       @relation("tag_permission_updated_byToaccount")
  user_info_user_info_account_idToaccount                       user_info[]            @relation("user_info_account_idToaccount")
  user_info_user_info_created_byToaccount                       user_info[]            @relation("user_info_created_byToaccount")
  user_info_user_info_updated_byToaccount                       user_info[]            @relation("user_info_updated_byToaccount")

  @@index([display_name], map: "idx_user_display_name")
  @@index([email], map: "idx_user_email")
}

model account_tag {
  id                                      String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  account_id                              String    @db.Uuid
  tag_id                                  String    @db.Uuid
  created_at                              DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                              DateTime? @db.Timestamptz(6)
  created_by                              String    @db.Uuid
  updated_by                              String?   @db.Uuid
  account_account_tag_account_idToaccount account   @relation("account_tag_account_idToaccount", fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_account_tag_account")
  account_account_tag_created_byToaccount account   @relation("account_tag_created_byToaccount", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_account_tag_created_by")
  tag                                     tag       @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_account_tag_tag")
  account_account_tag_updated_byToaccount account?  @relation("account_tag_updated_byToaccount", fields: [updated_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_account_tag_updated_by")

  @@unique([account_id, tag_id], map: "uk_account_tag")
}

model ambulance {
  id                                    String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  number                                String         @db.VarChar(255)
  created_at                            DateTime       @default(now()) @db.Timestamptz(6)
  updated_at                            DateTime?      @db.Timestamptz(6)
  created_by                            String         @db.Uuid
  updated_by                            String?        @db.Uuid
  type                                  ambulance_type
  account_ambulance_created_byToaccount account        @relation("ambulance_created_byToaccount", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ambulance_created_by")
  account_ambulance_updated_byToaccount account?       @relation("ambulance_updated_byToaccount", fields: [updated_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ambulance_updated_by")
  shift                                 shift[]
}

model area {
  id                               String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                             String         @db.VarChar(255)
  created_at                       DateTime       @default(now()) @db.Timestamptz(6)
  updated_at                       DateTime?      @db.Timestamptz(6)
  created_by                       String         @db.Uuid
  updated_by                       String?        @db.Uuid
  account_area_created_byToaccount account        @relation("area_created_byToaccount", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_area_created_by")
  account_area_updated_byToaccount account?       @relation("area_updated_byToaccount", fields: [updated_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_area_updated_by")
  launch_point                     launch_point[]
  user_info                        user_info[]
}

model emergency_contacts {
  id                                             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id                                        String    @db.Uuid
  name                                           String    @db.VarChar(255)
  relationship                                   String    @db.VarChar(255)
  phone                                          String    @db.VarChar(50)
  email                                          String?   @db.VarChar(255)
  address                                        String?
  created_at                                     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                                     DateTime? @db.Timestamptz(6)
  created_by                                     String    @db.Uuid
  updated_by                                     String?   @db.Uuid
  account_emergency_contacts_created_byToaccount account   @relation("emergency_contacts_created_byToaccount", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_emergency_contacts_created_by")
  account_emergency_contacts_updated_byToaccount account?  @relation("emergency_contacts_updated_byToaccount", fields: [updated_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_emergency_contacts_updated_by")
  user_info                                      user_info @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_emergency_contacts_user")
}

model launch_point {
  id                                       String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  area_id                                  String            @db.Uuid
  name                                     String            @db.VarChar(255)
  created_at                               DateTime          @default(now()) @db.Timestamptz(6)
  updated_at                               DateTime?         @db.Timestamptz(6)
  created_by                               String            @db.Uuid
  updated_by                               String?           @db.Uuid
  area                                     area              @relation(fields: [area_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_launch_point_area")
  account_launch_point_created_byToaccount account           @relation("launch_point_created_byToaccount", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_launch_point_created_by")
  account_launch_point_updated_byToaccount account?          @relation("launch_point_updated_byToaccount", fields: [updated_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_launch_point_updated_by")
  permanent_shift                          permanent_shift[]
  shift                                    shift[]
}

model notification {
  id                                       String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id                                  String    @db.Uuid
  title                                    String    @db.VarChar(255)
  message                                  String
  timestamp                                DateTime  @db.Timestamptz(6)
  read                                     Boolean   @default(false)
  created_at                               DateTime  @default(now()) @db.Timestamptz(6)
  created_by                               String    @db.Uuid
  updated_at                               DateTime? @db.Timestamptz(6)
  updated_by                               String?   @db.Uuid
  account_notification_created_byToaccount account   @relation("notification_created_byToaccount", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notification_created_by")
  account_notification_updated_byToaccount account?  @relation("notification_updated_byToaccount", fields: [updated_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notification_updated_by")
  account_notification_user_idToaccount    account   @relation("notification_user_idToaccount", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notification_user")
}

model password_reset_token {
  id                                               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  account_id                                       String    @db.Uuid
  token_hash                                       String
  expires_at                                       DateTime  @db.Timestamptz(6)
  created_at                                       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                                       DateTime? @db.Timestamptz(6)
  created_by                                       String    @db.Uuid
  updated_by                                       String?   @db.Uuid
  used                                             Boolean?  @default(false)
  account_password_reset_token_account_idToaccount account   @relation("password_reset_token_account_idToaccount", fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_password_reset_token_account")
  account_password_reset_token_created_byToaccount account   @relation("password_reset_token_created_byToaccount", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_password_reset_token_created_by")
  account_password_reset_token_updated_byToaccount account?  @relation("password_reset_token_updated_byToaccount", fields: [updated_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_password_reset_token_updated_by")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model permanent_shift {
  id                                          String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  launch_point_id                             String          @db.Uuid
  week_day                                    Int
  start_time                                  DateTime        @db.Time(6)
  end_time                                    DateTime        @db.Time(6)
  adult_only                                  Boolean         @default(false)
  number_of_slots                             Int             @default(1)
  created_at                                  DateTime        @default(now()) @db.Timestamptz(6)
  updated_at                                  DateTime?       @db.Timestamptz(6)
  created_by                                  String          @db.Uuid
  updated_by                                  String?         @db.Uuid
  shift_type                                  shift_type
  ambulance_type                              ambulance_type?
  start_date                                  DateTime?       @db.Date
  end_date                                    DateTime?       @db.Date
  overnight                                   Boolean?        @default(true)
  account_permanent_shift_created_byToaccount account         @relation("permanent_shift_created_byToaccount", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_permanent_shift_created_by")
  launch_point                                launch_point    @relation(fields: [launch_point_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_permanent_shift_launch_point")
  account_permanent_shift_updated_byToaccount account?        @relation("permanent_shift_updated_byToaccount", fields: [updated_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_permanent_shift_updated_by")

  @@index([launch_point_id], map: "idx_permanent_shift_launch_point_id")
  @@index([week_day], map: "idx_permanent_shift_week_day")
}

model permissions {
  id                                      String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                                    String           @unique @db.VarChar(255)
  created_at                              DateTime         @default(now()) @db.Timestamptz(6)
  updated_at                              DateTime?        @db.Timestamptz(6)
  created_by                              String           @db.Uuid
  updated_by                              String?          @db.Uuid
  account_permissions_created_byToaccount account          @relation("permissions_created_byToaccount", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_permissions_created_by")
  account_permissions_updated_byToaccount account?         @relation("permissions_updated_byToaccount", fields: [updated_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_permissions_updated_by")
  tag_permission                          tag_permission[]
}

model shift {
  id                                String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  driver_id                         String?           @db.Uuid
  launch_point_id                   String            @db.Uuid
  start_time                        DateTime?         @db.Time(6)
  end_time                          DateTime?         @db.Time(6)
  created_at                        DateTime          @default(now()) @db.Timestamptz(6)
  updated_at                        DateTime?         @db.Timestamptz(6)
  created_by                        String            @default(dbgenerated("'00000000-0000-0000-0000-000000000001'::uuid")) @db.Uuid
  updated_by                        String?           @db.Uuid
  start_date                        DateTime          @db.Date
  adult_only                        Boolean?          @default(false)
  number_of_slots                   Int?              @default(1)
  status                            shift_status_type @default(active)
  ambulance_id                      String?           @db.Uuid
  shift_type                        String?           @db.VarChar
  end_date                          DateTime?         @db.Date
  ambulance_type                    ambulance_type
  ambulance                         ambulance?        @relation(fields: [ambulance_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_shift_ambulance")
  account_shift_created_byToaccount account           @relation("shift_created_byToaccount", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_shift_created_by")
  account_shift_driver_idToaccount  account?          @relation("shift_driver_idToaccount", fields: [driver_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_shift_driver")
  launch_point                      launch_point      @relation(fields: [launch_point_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_shift_launch_point")
  account_shift_updated_byToaccount account?          @relation("shift_updated_byToaccount", fields: [updated_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_shift_updated_by")
  shift_slot                        shift_slot[]

  @@index([start_date], map: "idx_shift_date")
  @@index([driver_id], map: "idx_shift_driver_id")
  @@index([launch_point_id], map: "idx_shift_launch_point_id")
  @@index([status], map: "idx_shift_status")
}

model shift_slot {
  id                                     String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  shift_id                               String       @db.Uuid
  user_id                                String       @db.Uuid
  status                                 shift_status @default(pending)
  created_at                             DateTime     @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime?    @db.Timestamptz(6)
  created_by                             String       @db.Uuid
  updated_by                             String?      @db.Uuid
  account_shift_slot_created_byToaccount account      @relation("shift_slot_created_byToaccount", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_shift_slot_created_by")
  shift                                  shift        @relation(fields: [shift_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_shift_slot_shift")
  account_shift_slot_updated_byToaccount account?     @relation("shift_slot_updated_byToaccount", fields: [updated_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_shift_slot_updated_by")
  account_shift_slot_user_idToaccount    account      @relation("shift_slot_user_idToaccount", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_shift_slot_user")

  @@unique([shift_id, user_id], map: "uk_shift_slot")
}

model tag {
  id                              String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                            String           @db.VarChar(255)
  created_at                      DateTime         @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime?        @db.Timestamptz(6)
  created_by                      String           @db.Uuid
  updated_by                      String?          @db.Uuid
  category                        String?          @db.VarChar(255)
  account_tag                     account_tag[]
  account_tag_created_byToaccount account          @relation("tag_created_byToaccount", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tag_created_by")
  account_tag_updated_byToaccount account?         @relation("tag_updated_byToaccount", fields: [updated_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tag_updated_by")
  tag_permission                  tag_permission[]
}

model tag_permission {
  id                                         String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tag_id                                     String      @db.Uuid
  permission_id                              String      @db.Uuid
  created_at                                 DateTime    @default(now()) @db.Timestamptz(6)
  updated_at                                 DateTime?   @db.Timestamptz(6)
  created_by                                 String      @db.Uuid
  updated_by                                 String?     @db.Uuid
  account_tag_permission_created_byToaccount account     @relation("tag_permission_created_byToaccount", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tag_permission_created_by")
  permissions                                permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tag_permission_permission")
  tag                                        tag         @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tag_permission_tag")
  account_tag_permission_updated_byToaccount account?    @relation("tag_permission_updated_byToaccount", fields: [updated_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tag_permission_updated_by")

  @@unique([tag_id, permission_id], map: "uk_tag_permission")
}

model user_info {
  id                                    String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  account_id                            String               @db.Uuid
  first_name                            String?              @db.VarChar(255)
  last_name                             String?              @db.VarChar(255)
  address                               String?
  created_at                            DateTime             @default(now()) @db.Timestamptz(6)
  updated_at                            DateTime?            @db.Timestamptz(6)
  created_by                            String               @db.Uuid
  updated_by                            String?              @db.Uuid
  image_url                             String?
  role                                  String?              @db.VarChar(255)
  area_id                               String?              @db.Uuid
  active                                Boolean              @default(false)
  active_date                           DateTime?            @db.Date
  emergency_contacts                    emergency_contacts[]
  account_user_info_account_idToaccount account              @relation("user_info_account_idToaccount", fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_info_account")
  area                                  area?                @relation(fields: [area_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_info_area")
  account_user_info_created_byToaccount account              @relation("user_info_created_byToaccount", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_info_created_by")
  account_user_info_updated_byToaccount account?             @relation("user_info_updated_byToaccount", fields: [updated_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_info_updated_by")
}

enum ambulance_type {
  white
  atan
}

enum shift_status {
  pending
  confirmed
  cancelled
}

enum shift_status_type {
  active
  canceled
}

enum shift_type {
  day
  evening
  night
}
